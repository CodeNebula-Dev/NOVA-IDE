{
  "name": "nova-ide",
  "productName": "Nova IDE",
  "version": "1.0.0",
  "description": "Nova IDE — AI-agent-first desktop code editor built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "ide",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.2",
    "fast-check": "^3.23.2",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8"
  },
  "vitest": {
    "environment": "jsdom",
    "include": [
      "renderer/tests/**/*.test.js"
    ],
    "setupFiles": [
      "renderer/tests/test-setup.js"
    ]
  }
}
