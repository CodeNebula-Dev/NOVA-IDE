{
  "appId": "com.nova.ide",
  "productName": "Nova IDE",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "main/**/*.js",
    "renderer/**/*",
    "assets/**/*",
    "!renderer/tests/**/*",
    "!node_modules/**/*.map",
    "!node_modules/**/*.md"
  ],
  "mac": {
    "target": [
      "dmg"
    ],
    "icon": "assets/icon.png",
    "category": "public.app-category.developer-tools"
  },
  "dmg": {
    "title": "Nova IDE",
    "icon": "assets/icon.png",
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  }
}
